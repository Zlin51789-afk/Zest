{
  "name": "apple-ai-assistant",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --env-file=.env server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node --env-file=.env server/index.js",
    "serve:local": "npm run build && node --env-file=.env server/serve-local.js",
    "local": "bash scripts/start-local-chipgo.sh",
    "local:3001": "npm run serve:local",
    "public": "bash scripts/start-public-server.sh",
    "setup:public": "bash scripts/setup-public-chipgo.sh",
    "fix:dns": "bash scripts/fix-cloudflare-dns-records.sh",
    "cf:delete-wildcard": "python3 scripts/delete-cf-wildcard-a.py",
    "hosts:chipgo": "bash scripts/enable-chipgo-hosts.sh",
    "setup:local": "bash scripts/setup-local-only.sh",
    "setup:autostart": "bash scripts/install-launchd.sh",
    "autostart:uninstall": "bash scripts/uninstall-launchd.sh"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "vite": "^6.0.3"
  }
}
