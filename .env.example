# 本地：OpenClaw Gateway（默认读取 ~/.openclaw/openclaw.json）
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token
OPENCLAW_MODEL=openclaw/main

# 云端 Vercel：直连 Moonshot（与 OpenClaw 使用同一 Kimi 模型）
AI_BACKEND=moonshot
MOONSHOT_API_KEY=sk-your-moonshot-key
MOONSHOT_MODEL=kimi-k2.6

# 可选：加快回答（限制生成长度；多数 Kimi 模型不要设置 temperature，由接口默认即可）
# MOONSHOT_MAX_TOKENS=1024
# 仅当 Moonshot 文档要求时再设，例如部分模型需固定为 1：
# MOONSHOT_TEMPERATURE=1
# MOONSHOT_MAX_ATTEMPTS=2
# OPENCLAW_MAX_TOKENS=1024
# OPENCLAW_TEMPERATURE=0.35

# 可选：自定义 OpenClaw 配置文件路径
# OPENCLAW_CONFIG_PATH=/Users/you/.openclaw/openclaw.json

PORT=3001
